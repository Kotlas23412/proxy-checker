            "domain:tander.ru",
            "domain:magnit.ru",
            "regexp:.*\\.tander\\..*",
            "regexp:.*tander.*magnit.*",
            "regexp:.*magnit.*tander.*"
          ],
          "outboundTag": "direct",
          "type": "field"
