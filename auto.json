      "balancers": [
        {
          "tag": "balancer-main",
          "fallbackTag": "proxy-0",
          "selector": [
            "proxy-"
          ],
          "strategy": {
            "type": "leastLoad",
            "settings": {
              "expected": 1,
              "maxRTT": "5s",
              "tolerance": 0.5,
              "baselines": [
                "800ms",
                "2000ms"
              ]
            }
          }
        }
      ],
